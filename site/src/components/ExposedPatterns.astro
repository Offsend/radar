---
import type { CollectionEntry } from 'astro:content';
import { formatPatternLabel, formatSeverityLabel, severityRank } from '../lib/labels';
import { patternGuideSlugById } from '../lib/guides';

interface Props {
	summary: CollectionEntry<'summaries'>;
}

const { summary } = Astro.props;
const patterns = [...summary.data.exposedPatterns].sort(
	(a, b) => severityRank(a.severity) - severityRank(b.severity) || b.totalCount - a.totalCount,
);
---

<div class="card">
	<h3>AI-context risk signal categories</h3>
	<p class="card-scope">Aggregated path pattern counts — not tied to any named repository.</p>
	{patterns.length === 0 ? (
		<p class="empty-state-inline">No AI-context risk signal categories this week.</p>
	) : (
		<ul class="finding-list">
			{patterns.map((pattern) => {
				const slug = patternGuideSlugById(pattern.id);
				return (
					<li class="finding-item">
						<span class="finding-name">
							{slug ? (
								<a class="finding-label finding-link" href={`/patterns/${slug}/`}>
									{formatPatternLabel(pattern.id)}
								</a>
							) : (
								<span class="finding-label">{formatPatternLabel(pattern.id)}</span>
							)}
							<span class={`sev sev-${pattern.severity}`}>{formatSeverityLabel(pattern.severity)}</span>
						</span>
						<span class="finding-meta">
							{pattern.reposAffected} {pattern.reposAffected === 1 ? 'repo' : 'repos'} · {pattern.totalCount}{' '}
							{pattern.totalCount === 1 ? 'match' : 'matches'}
						</span>
					</li>
				);
			})}
		</ul>
	)}
</div>

<style>
	.card-scope {
		margin: -0.5rem 0 1rem;
		font-size: 0.85rem;
		color: var(--text-mut);
		line-height: 1.4;
	}

	.empty-state-inline {
		margin: 0;
		color: var(--text-mut);
		font-size: 0.95rem;
	}

	.finding-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.finding-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 0.65rem 0.35rem;
		margin: 0 -0.35rem;
		border-bottom: 1px solid var(--border);
		border-radius: var(--r-sm);
		transition: background 0.15s ease;
	}

	.finding-item:hover {
		background: oklch(44% 0.14 264 / 0.04);
	}

	.finding-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.finding-name {
		display: inline-flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.5rem;
		min-width: 0;
	}

	.finding-label {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text);
	}

	.sev {
		flex-shrink: 0;
		align-self: center;
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 0.1em 0.45em;
		border-radius: 999px;
		white-space: nowrap;
	}

	.sev-required {
		background: var(--red-dim);
		color: var(--red-text);
	}

	.sev-recommended {
		background: var(--amber-dim);
		color: var(--amber-text);
	}

	.sev-informational {
		background: var(--bg-2);
		color: var(--text-mut);
	}

	.finding-link {
		color: var(--text);
		transition: color 0.15s ease;
	}

	.finding-link:hover {
		color: var(--blue-text);
		text-decoration: underline;
	}

	.finding-meta {
		flex-shrink: 0;
		font-size: 0.85rem;
		color: var(--text-mut);
	}
</style>
