---
import type { CollectionEntry } from 'astro:content';
import { formatIgnoreLabel } from '../lib/labels';
import { ignoreGuideSlugById } from '../lib/guides';
import {
	formatPct,
	getAllIgnoreRules,
	getDedicatedAiIgnoreCoverage,
	getNonZeroIgnoreRules,
	getPriorityDedicatedIgnoreRules,
} from '../lib/summaries';

interface Props {
	summary: CollectionEntry<'summaries'>;
}

const { summary } = Astro.props;

const dedicatedCoverage = getDedicatedAiIgnoreCoverage(summary);
const priorityRules = getPriorityDedicatedIgnoreRules(summary);
const nonZeroRules = getNonZeroIgnoreRules(summary);
const allRules = getAllIgnoreRules(summary);
const extraRules = allRules.filter(([id]) => !priorityRules.some(([priorityId]) => priorityId === id));
---

<div class="card">
	<h2>Dedicated AI ignore files</h2>
	<p class="coverage-summary">
		<span class="coverage-stat">
			<strong>{formatPct(dedicatedCoverage)}</strong> dedicated AI ignore coverage
		</span>
	</p>
	<p class="coverage-insight">
		Dedicated AI ignore files are still rare.
	</p>

	{priorityRules.map(([id, rule]) => (
		<div class="bar-row">
			{ignoreGuideSlugById(id) ? (
				<a class="bar-label bar-label-link" href={`/ignore-files/${ignoreGuideSlugById(id)}/`}>
					{formatIgnoreLabel(id)}
				</a>
			) : (
				<span class="bar-label">{formatIgnoreLabel(id)}</span>
			)}
			<div class="bar-track">
				<div
					class="bar-fill"
					class:list={{ 'bar-fill-zero': rule.pct === 0 }}
					style={`width: ${Math.max(Math.round(rule.pct * 100), rule.pct > 0 ? 2 : 0)}%`}
				/>
			</div>
			<span class="bar-pct">{formatPct(rule.pct)}</span>
		</div>
	))}

	{extraRules.length > 0 && (
		<details class="ignore-details">
			<summary>
				Show {extraRules.length} more dedicated ignore type{extraRules.length === 1 ? '' : 's'}
				{nonZeroRules.length > 0 && ` (${nonZeroRules.length} in use overall)`}
			</summary>
			<div class="ignore-details-list">
				{extraRules.map(([id, rule]) => (
					<div class="bar-row bar-row-compact">
						{ignoreGuideSlugById(id) ? (
							<a class="bar-label bar-label-link" href={`/ignore-files/${ignoreGuideSlugById(id)}/`}>
								{formatIgnoreLabel(id)}
							</a>
						) : (
							<span class="bar-label">{formatIgnoreLabel(id)}</span>
						)}
						<div class="bar-track">
							<div
								class="bar-fill"
								class:list={{ 'bar-fill-zero': rule.pct === 0 }}
								style={`width: ${Math.max(Math.round(rule.pct * 100), rule.pct > 0 ? 2 : 0)}%`}
							/>
						</div>
						<span class="bar-pct">{formatPct(rule.pct)}</span>
					</div>
				))}
			</div>
		</details>
	)}
</div>

<style>
	.coverage-summary {
		margin: -0.25rem 0 0.5rem;
		font-size: 0.95rem;
		color: var(--text-sub);
	}

	.coverage-stat strong {
		color: var(--text);
		font-weight: 600;
	}

	.coverage-insight {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		color: var(--text-mut);
		line-height: 1.45;
	}

	.bar-row {
		grid-template-columns: minmax(140px, 1fr) 1fr 52px;
	}

	.bar-label-link {
		color: var(--text-sub);
		transition: color 0.15s ease;
	}

	.bar-label-link:hover {
		color: var(--blue-text);
		text-decoration: underline;
	}

	.ignore-details {
		margin-top: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
	}

	.ignore-details summary {
		cursor: pointer;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-sub);
		list-style: none;
	}

	.ignore-details summary::-webkit-details-marker {
		display: none;
	}

	.ignore-details-list {
		margin-top: 0.75rem;
	}

	.bar-row-compact {
		padding: 0.25rem 0;
	}

	.bar-fill-zero {
		opacity: 0.35;
	}
</style>
