---
import type { CollectionEntry } from 'astro:content';
import { formatPct } from '../lib/summaries';

interface Props {
	summary: CollectionEntry<'summaries'>;
	limit?: number;
}

const { summary, limit = 12 } = Astro.props;

const rules = Object.entries(summary.data.ignoreFilesPresent)
	.sort(([, a], [, b]) => b.pct - a.pct)
	.slice(0, limit);
---

<div class="card">
	<h2>Ignore file coverage</h2>
	{rules.length === 0 ? (
		<p class="empty-state">No ignore rules in this week's data.</p>
	) : (
		<div>
			{rules.map(([id, rule]) => (
				<div class="bar-row">
					<span class="bar-label mono">{id}</span>
					<div class="bar-track">
						<div class="bar-fill" style={`width: ${Math.round(rule.pct * 100)}%`} />
					</div>
					<span class="bar-pct">{formatPct(rule.pct)}</span>
				</div>
			))}
		</div>
	)}
</div>
