---
import type { SummaryEntry } from '../lib/summaries';
import { buildMainTakeaway } from '../lib/summaries';

interface Props {
	summary: SummaryEntry;
}

const { summary } = Astro.props;
const paragraphs = buildMainTakeaway(summary);

function renderParagraph(text: string) {
	const parts = text.split(/(`[^`]+`)/g);
	return parts.map((part) => {
		if (part.startsWith('`') && part.endsWith('`')) {
			return `<code>${part.slice(1, -1)}</code>`;
		}
		return part;
	}).join('');
}
---

<div class="card card-featured main-takeaway">
	<h2>Main takeaway</h2>
	{paragraphs.map((paragraph) => (
		<p set:html={renderParagraph(paragraph)} />
	))}
</div>

<style>
	.main-takeaway h2 {
		margin: 0 0 0.75rem;
		font-family: var(--heading);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text);
	}

	.main-takeaway p {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text-sub);
		line-height: 1.5;
	}

	.main-takeaway p + p {
		margin-top: 0.5rem;
	}

	.main-takeaway :global(code) {
		font-family: var(--mono);
		font-size: 0.88em;
		background: var(--bg-2);
		padding: 0.1em 0.35em;
		border-radius: 4px;
	}
</style>
