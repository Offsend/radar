---
import ShareReportButton from './ShareReportButton.astro';
import { formatGeneratedAt, formatReportHeading } from '../lib/summaries';
import type { SummaryEntry } from '../lib/summaries';

interface Props {
	summary: SummaryEntry;
	summaries: SummaryEntry[];
	headingLevel?: 'h1' | 'h2';
}

const { summary, summaries, headingLevel = 'h1' } = Astro.props;
const heading = formatReportHeading(summaries, summary.data.week);
const Heading = headingLevel;
---

<header class="page-header">
	<div class="page-header-row">
		<Heading>{heading.title}</Heading>
		<ShareReportButton week={summary.data.week} summaries={summaries} />
	</div>
	<p>
		{heading.tagline && <>{heading.tagline} · </>}
		Published {formatGeneratedAt(summary.data.generatedAt)} UTC
	</p>
</header>
