---
import type { SummaryEntry } from '../lib/summaries';
import { getReportLabel } from '../lib/summaries';

interface Props {
	summaries: SummaryEntry[];
}

const { summaries } = Astro.props;
const chronological = [...summaries].sort((a, b) => a.data.week.localeCompare(b.data.week));
---

<div class="card">
	<h2>Trend</h2>
	{summaries.length < 2 ? (
		<p class="empty-state">More weekly reports will appear here as scans accumulate.</p>
	) : (
		<ul class="trend-list">
			{summaries.map((entry) => (
				<li>
					<a href={`/week/${entry.data.week}`}>{getReportLabel(chronological, entry.data.week)}</a>
					<span>
						{entry.data.totals.totalExposedFiles} risk signals · {entry.data.cohort.scanComplete} repos
					</span>
				</li>
			))}
		</ul>
	)}
</div>
