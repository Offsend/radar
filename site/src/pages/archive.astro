---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllSummaries, formatGeneratedAt, getReportLabel } from '../lib/summaries';

const summaries = await getAllSummaries();
const chronological = [...summaries].sort((a, b) => a.data.week.localeCompare(b.data.week));
---

<BaseLayout
	title="Archive"
	activeNav="archive"
	description="All published Offsend Radar fleet reports — weekly AI-context hygiene scans with anonymous aggregates."
>
	<header class="page-header">
		<h1>Archive</h1>
		<p>All published weekly fleet summaries.</p>
	</header>

	<div class="card">
		{summaries.length === 0 ? (
			<p class="empty-state">No reports published yet.</p>
		) : (
			<div class="table-wrap">
				<table>
					<thead>
						<tr>
							<th>Report</th>
							<th>Generated</th>
							<th>Scanned</th>
							<th>Risk signals</th>
							<th>AI-context risk signals</th>
						</tr>
					</thead>
					<tbody>
						{summaries.map((entry) => (
							<tr>
								<td>
									<a href={`/week/${entry.data.week}`}>{getReportLabel(chronological, entry.data.week)}</a>
									<span class="report-week-id mono">{entry.data.week}</span>
								</td>
								<td>{formatGeneratedAt(entry.data.generatedAt)}</td>
								<td>{entry.data.cohort.scanComplete}</td>
								<td>{entry.data.totals.reposWithExposures}</td>
								<td>{entry.data.totals.totalExposedFiles}</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		)}
	</div>
</BaseLayout>
