---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportHero from '../components/ReportHero.astro';
import ReportPageHeader from '../components/ReportPageHeader.astro';
import ReportSections from '../components/ReportSections.astro';
import { getAllSummaries, getLatestSummary } from '../lib/summaries';
import { buildReportPageTitle, buildSummaryPageDescription, ogImagePathForWeek } from '../lib/seo';

const summaries = await getAllSummaries();
const latest = await getLatestSummary();
const pageDescription = latest ? buildSummaryPageDescription(latest) : undefined;
---

<BaseLayout
	title={latest ? buildReportPageTitle(summaries, latest.data.week) : 'Offsend Radar'}
	activeNav="home"
	description={pageDescription}
	ogImage={latest ? ogImagePathForWeek(latest.data.week) : undefined}
>
	{latest ? (
		<>
			<ReportHero summary={latest} />

			<ReportPageHeader summary={latest} summaries={summaries} headingLevel="h2" />

			<ReportSections summary={latest} summaries={summaries} showTrend />
		</>
	) : (
		<div class="card empty-state">
			<h1>No reports yet</h1>
			<p>Weekly summaries will appear after the first Offsend Radar scan.</p>
		</div>
	)}
</BaseLayout>
