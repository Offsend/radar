---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportSections from '../components/ReportSections.astro';
import { getAllSummaries, getLatestSummary, formatGeneratedAt } from '../lib/summaries';

const summaries = await getAllSummaries();
const latest = await getLatestSummary();
---

<BaseLayout title="Offsend Radar" activeNav="home">
	{latest ? (
		<>
			<header class="page-header">
				<h1>Week {latest.data.week}</h1>
				<p>Published {formatGeneratedAt(latest.data.generatedAt)} UTC</p>
			</header>

			<ReportSections summary={latest} summaries={summaries} showTrend />
		</>
	) : (
		<div class="card empty-state">
			<h1>No reports yet</h1>
			<p>Weekly summaries will appear after the first Offsend Radar scan.</p>
		</div>
	)}
</BaseLayout>
