---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportSections from '../components/ReportSections.astro';
import {
	getAllSummaries,
	getLatestSummary,
	formatGeneratedAt,
	formatReportHeading,
} from '../lib/summaries';
import { buildSummaryPageDescription } from '../lib/seo';

const summaries = await getAllSummaries();
const latest = await getLatestSummary();
const heading = latest ? formatReportHeading(summaries, latest.data.week) : undefined;
const pageDescription = latest ? buildSummaryPageDescription(latest) : undefined;
---

<BaseLayout
	title="Offsend Radar"
	activeNav="home"
	description={pageDescription}
>
	{latest ? (
		<>
			<header class="page-header">
				<h1>{heading?.title}</h1>
				<p>
					{heading?.tagline && <>{heading.tagline} · </>}
					Published {formatGeneratedAt(latest.data.generatedAt)} UTC
				</p>
			</header>

			<ReportSections summary={latest} summaries={summaries} showTrend />
		</>
	) : (
		<div class="card empty-state">
			<h1>No reports yet</h1>
			<p>Weekly summaries will appear after the first Offsend Radar scan.</p>
		</div>
	)}
</BaseLayout>
