---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportSections from '../../components/ReportSections.astro';
import { getAllSummaries, getSummaryByWeek, formatGeneratedAt } from '../../lib/summaries';

export async function getStaticPaths() {
	const summaries = await getAllSummaries();
	return summaries.map((entry) => ({
		params: { week: entry.data.week },
	}));
}

const { week } = Astro.params;
const summaries = await getAllSummaries();
const summary = week ? await getSummaryByWeek(week) : undefined;

if (!summary) {
	return Astro.redirect('/archive');
}
---

<BaseLayout title={`Week ${summary.data.week}`} activeNav="archive">
	<header class="page-header">
		<h1>Week {summary.data.week}</h1>
		<p>Published {formatGeneratedAt(summary.data.generatedAt)} UTC</p>
	</header>

	<ReportSections summary={summary} summaries={summaries} />
</BaseLayout>
