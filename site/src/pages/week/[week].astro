---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportSections from '../../components/ReportSections.astro';
import {
	getAllSummaries,
	getSummaryByWeek,
	formatGeneratedAt,
	formatReportHeading,
} from '../../lib/summaries';
import { buildReportSchema, buildSummaryPageDescription } from '../../lib/seo';

export async function getStaticPaths() {
	const summaries = await getAllSummaries();
	return summaries.map((entry) => ({
		params: { week: entry.data.week },
	}));
}

const { week } = Astro.params;
const summaries = await getAllSummaries();
const summary = week ? await getSummaryByWeek(week) : undefined;

if (!summary) {
	return Astro.redirect('/archive');
}

const heading = formatReportHeading(summaries, summary.data.week);
const pageDescription = buildSummaryPageDescription(summary);
const reportSchema = buildReportSchema(summary, summaries, Astro.url.pathname);
---

<BaseLayout
	title={heading.title}
	activeNav="archive"
	description={pageDescription}
	jsonLd={reportSchema}
>
	<header class="page-header">
		<h1>{heading.title}</h1>
		<p>
			{heading.tagline && <>{heading.tagline} · </>}
			Published {formatGeneratedAt(summary.data.generatedAt)} UTC
		</p>
	</header>

	<ReportSections summary={summary} summaries={summaries} />
</BaseLayout>
