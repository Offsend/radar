---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportPageHeader from '../../components/ReportPageHeader.astro';
import ReportSections from '../../components/ReportSections.astro';
import { getAllSummaries, getSummaryByWeek } from '../../lib/summaries';
import {
	buildReportPageTitle,
	buildReportSchema,
	buildSummaryPageDescription,
	ogImagePathForWeek,
} from '../../lib/seo';

export async function getStaticPaths() {
	const summaries = await getAllSummaries();
	return summaries.map((entry) => ({
		params: { week: entry.data.week },
	}));
}

const { week } = Astro.params;
const summaries = await getAllSummaries();
const summary = week ? await getSummaryByWeek(week) : undefined;

if (!summary) {
	return Astro.redirect('/archive');
}

const pageDescription = buildSummaryPageDescription(summary);
const reportSchema = buildReportSchema(summary, summaries, Astro.url.pathname);
---

<BaseLayout
	title={buildReportPageTitle(summaries, summary.data.week)}
	activeNav="archive"
	description={pageDescription}
	ogImage={ogImagePathForWeek(summary.data.week)}
	jsonLd={reportSchema}
>
	<ReportPageHeader summary={summary} summaries={summaries} />

	<ReportSections summary={summary} summaries={summaries} />
</BaseLayout>
