---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CohortCard from '../../components/CohortCard.astro';
import IgnoreCoverage from '../../components/IgnoreCoverage.astro';
import ExposedPatterns from '../../components/ExposedPatterns.astro';
import { getAllSummaries, getSummaryByWeek, formatGeneratedAt } from '../../lib/summaries';

export async function getStaticPaths() {
	const summaries = await getAllSummaries();
	return summaries.map((entry) => ({
		params: { week: entry.data.week },
	}));
}

const { week } = Astro.params;
const summary = week ? await getSummaryByWeek(week) : undefined;

if (!summary) {
	return Astro.redirect('/archive');
}
---

<BaseLayout title={`Week ${summary.data.week}`} activeNav="archive">
	<header class="page-header">
		<h1>Week {summary.data.week}</h1>
		<p>
			Generated {formatGeneratedAt(summary.data.generatedAt)} UTC · ruleset
			<span class="mono"> {summary.data.rulesetVersions[0]} </span>
		</p>
	</header>

	<div class="grid" style="gap: 1.5rem">
		<CohortCard summary={summary} />
		<ExposedPatterns summary={summary} />
		<IgnoreCoverage summary={summary} />
	</div>
</BaseLayout>
